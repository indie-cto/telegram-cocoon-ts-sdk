{
  "name": "cocoon-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Telegram Cocoon — decentralized GPU network for AI inference on TON",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "cocoon:setup": "npx tsx --env-file=.env scripts/setup.ts",
    "cocoon:inference": "npx tsx --env-file=.env scripts/inference.ts",
    "cocoon:discover": "npx tsx scripts/discover.ts",
    "cocoon:register": "npx tsx --env-file=.env scripts/register.ts",
    "cocoon:create-wallet": "npx tsx scripts/create-wallet.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@ton/ton": "^16.0.0",
    "@ton/core": "^0.63.0",
    "@ton/crypto": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
