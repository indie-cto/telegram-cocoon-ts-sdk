# Cocoon SDK Configuration
# Copy this to .env and fill in your values

# Required: 24-word TON wallet mnemonic
MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# Filled by scripts/setup.ts (recommended). Keep empty before first setup run.
SECRET=

# Optional: mainnet or testnet (default: mainnet)
NETWORK=mainnet

# Optional: direct proxy address (skip discovery)
# PROXY_URL=91.108.4.11:8888

# Optional: custom TON JSON-RPC endpoint (recommended if default toncenter is rate-limited)
# TON_ENDPOINT=https://your-ton-rpc.example/jsonRPC
# Optional: TON v4 endpoint for sending wallet tx (helps avoid toncenter 429)
# TON_V4_ENDPOINT=https://mainnet-v4.tonhubapi.com

# Optional: RA-TLS / mTLS client credentials (PEM)
# COCOON_TLS_CERT_PATH=/path/to/client-cert.pem
# COCOON_TLS_KEY_PATH=/path/to/client-key.pem

# Advanced (usually do not change)
# REGISTER_TON=1
# CHANGE_SECRET_TON=0.7
# TOP_UP_TON=16
